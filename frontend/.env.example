# Supabase — عرّف المشروع في لوحة Supabase → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# مفتاح المتصفح (anon أو publishable حسب لوحة Supabase)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-publishable-or-anon-key
# أو: NEXT_PUBLIC_SUPABASE_ANON_KEY=...

# يُستخدم فقط على الخادم (Server Components / Server Actions). لا تُضمَّن في العميل.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret

# Prisma 6 + Supabase pooler (استبدل كلمة المرور من لوحة Supabase → Connect)
# DATABASE_URL="postgresql://postgres.PROJECT_REF:[PASSWORD]@REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.PROJECT_REF:[PASSWORD]@REGION.pooler.supabase.com:5432/postgres"

# ----- Phase 2b — DASM JWT (اختياري؛ الافتراضي بدون إنفاذ) -----
# ضع true لتفعيل middleware على مسارات التطبيق الرئيسية
# DASM_JWT_ENFORCE=false

# إلزامي عند DASM_JWT_ENFORCE=true
# DASM_JWT_ISSUER=https://auth.dasm.example

# اختياري — يُتحقق من aud عند التعريف
# DASM_JWT_AUDIENCE=inspection

# HS256: سر مشترك (تطوير / بعض تكاملات البوابة)
# DASM_JWT_SECRET=

# أو RS256/ES256: عنوان JWKS (يفضّل للإنتاج)
# DASM_JWKS_URI=https://auth.dasm.example/.well-known/jwks.json

# كوكي بديلة لـ Bearer (اسم الكوكي)
# DASM_JWT_COOKIE_NAME=dasm_access_token

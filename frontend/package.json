{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test:unit": "vitest run",
    "prisma:generate": "dotenv -e .env.local -- prisma generate",
    "prisma:validate": "dotenv -e .env.local -- prisma validate",
    "prisma:studio": "dotenv -e .env.local -- prisma studio",
    "prisma:db:pull": "dotenv -e .env.local -- prisma db pull",
    "prisma:migrate:dev": "dotenv -e .env.local -- prisma migrate dev"
  },
  "dependencies": {
    "@prisma/client": "6.19.0",
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.101.1",
    "clsx": "^2.1.1",
    "jose": "^5.9.6",
    "next": "14.2.35",
    "react": "^18",
    "react-dom": "^18",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "dotenv-cli": "^11.0.0",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "prisma": "6.19.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vitest": "^2.1.9"
  }
}
